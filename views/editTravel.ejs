<%- include("partials/header") %>

<div class="form-container">

    <h1>Edit Travel</h1>

    <form action="/editTravel/<%= trip.id %>" method="POST" enctype="multipart/form-data">

        <div class="form-row">

            <div class="form-group">
                <label>Destination</label>
                <input
                    type="text"
                    name="destination"
                    value="<%= trip.destination %>"
                    required>
            </div>

            <div class="form-group">
                <label>Country</label>
                <input
                    type="text"
                    name="country"
                    value="<%= trip.country %>"
                    required>
            </div>

        </div>

        <div class="form-row">

            <div class="form-group">
                <label>Start Date</label>
                <input
                    type="date"
                    name="startDate"
                    value="<%= trip.startDate.toISOString().split('T')[0] %>"
                    required>
            </div>

            <div class="form-group">
                <label>End Date</label>
                <input
                    type="date"
                    name="endDate"
                    value="<%= trip.endDate.toISOString().split('T')[0] %>"
                    required>
            </div>

        </div>

        <div class="form-group">

            <label>Budget (SGD)</label>

            <input
                type="number"
                step="0.01"
                name="budget"
                value="<%= trip.budget %>"
                required>

        </div>

        <div class="form-group">

            <label>Current Image</label>

            <% if(trip.image){ %>

                <img
                    src="/images/<%= trip.image %>"
                    class="edit-image">

            <% } %>

        </div>

        <div class="form-group">

            <label>Upload New Image</label>

            <input
                type="file"
                name="destinationImage"
                accept="image/*">

        </div>

        <div class="form-group">

            <label>Notes</label>

            <textarea
                name="notes"
                rows="6"><%= trip.notes %></textarea>

        </div>

        <button class="save-btn">
            Update Travel
        </button>

    </form>

</div>

</body>
</html>

<%- include("partials/header") %>

<div class="container">

    <h1>Delete Trip</h1>

    <% if(success.length > 0){ %>

        <div class="success-message">

            <%= success %>

        </div>

    <% } %>

    <% if(error.length > 0){ %>

        <div class="error-message">

            <%= error %>

        </div>

    <% } %>

    <div class="delete-confirmation">

        <p>Are you sure you want to delete this trip?</p>

        <div class="trip-details">

            <p><strong>Destination:</strong> <%= trip.destination %></p>

            <p><strong>Country:</strong> <%= trip.country %></p>

            <p><strong>Travel Dates:</strong> 
                <%= new Date(trip.startDate).toLocaleDateString() %> - 
                <%= new Date(trip.endDate).toLocaleDateString() %>
            </p>

            <p><strong>Budget:</strong> S$<%= Number(trip.budget).toFixed(2) %></p>

            <% if(trip.notes){ %>

                <p><strong>Notes:</strong> <%= trip.notes %></p>

            <% } %>

        </div>

        <div class="delete-actions">

            <form action="/deleteTravel/<%= trip.id %>" method="POST">

                <button type="submit" class="delete-btn">

                    Confirm Delete

                </button>

            </form>

            <a href="/trips" class="cancel-btn">

                Cancel

            </a>

        </div>

    </div>

</div>

</body>
</html>
