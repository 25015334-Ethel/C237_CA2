<%- include("partials/header") %>

<div class="form-container">

    <h1>Edit Travel</h1>

    <form action="/editTravel/<%= trip.id %>" method="POST" enctype="multipart/form-data">

        <div class="form-row">

            <div class="form-group">
                <label>Destination</label>
                <input
                    type="text"
                    name="destination"
                    value="<%= trip.destination %>"
                    required>
            </div>

            <div class="form-group">
                <label>Country</label>
                <input
                    type="text"
                    name="country"
                    value="<%= trip.country %>"
                    required>
            </div>

        </div>

        <div class="form-row">

            <div class="form-group">
                <label>Start Date</label>
                <input
                    type="date"
                    name="startDate"
                    value="<%= trip.startDate.toISOString().split('T')[0] %>"
                    required>
            </div>

            <div class="form-group">
                <label>End Date</label>
                <input
                    type="date"
                    name="endDate"
                    value="<%= trip.endDate.toISOString().split('T')[0] %>"
                    required>
            </div>

        </div>

        <div class="form-group">

            <label>Budget (SGD)</label>

            <input
                type="number"
                step="0.01"
                name="budget"
                value="<%= trip.budget %>"
                required>

        </div>

        <div class="form-group">

            <label>Current Image</label>

            <% if(trip.image){ %>

                <img
                    src="/images/<%= trip.image %>"
                    class="edit-image">

            <% } %>

        </div>

        <div class="form-group">

            <label>Upload New Image</label>

            <input
                type="file"
                name="destinationImage"
                accept="image/*">

        </div>

        <div class="form-group">

            <label>Notes</label>

            <textarea
                name="notes"
                rows="6"><%= trip.notes %></textarea>

        </div>

        <button class="save-btn">
            Update Travel
        </button>

    </form>

</div>

</body>
</html>