<%- include("partials/header") %>

<div class="auth-container">

    <h1>Create Account</h1>

    <p>Create your Travel Planner account.</p>

    <% if(error.length > 0){ %>

        <div class="error-message">

            <%= error %>

        </div>

    <% } %>

    <form action="/register" method="POST">

        <label for="username">

            Username

        </label>

        <input
            type="text"
            id="username"
            name="username"
            placeholder="Enter your username"
            required>

        <label for="email">

            Email

        </label>

        <input
            type="email"
            id="email"
            name="email"
            placeholder="Enter your email"
            required>

        <label for="password">

            Password

        </label>

        <input
            type="password"
            id="password"
            name="password"
            placeholder="Enter your password"
            required>

        <label for="role">

            Account Type

        </label>

        <select
            id="role"
            name="role">

            <option value="user">

                Regular User (Personal Trips)

            </option>

            <option value="corporate">

                Corporate User

            </option>

        </select>

        <button type="submit">

            Register

        </button>

    </form>

    <div class="register-link">

        Already have an account?

        <a href="/login">

            Login here

        </a>

    </div>

</div>

</body>
</html>