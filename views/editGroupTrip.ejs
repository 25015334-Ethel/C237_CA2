<%- include("partials/header") %>

<div class="form-container">

    <h1>Edit Group Trip</h1>

    <% if(success.length > 0){ %>
        <div class="success-message">
            <%= success %>
        </div>
    <% } %>

    <% if(error.length > 0){ %>
        <div class="error-message">
            <%= error %>
        </div>
    <% } %>

    <form action="/editGroupTrip/<%= trip.id %>" method="POST">

        <div class="form-row">

            <div class="form-group">
                <label>Group Name</label>
                <input
                    type="text"
                    name="groupName"
                    value="<%= trip.groupName %>"
                    required>
            </div>

            <div class="form-group">
                <label>Destination</label>
                <input
                    type="text"
                    name="destination"
                    value="<%= trip.destination %>"
                    required>
            </div>

        </div>

        <div class="form-row">

            <div class="form-group">
                <label>Country</label>
                <input
                    type="text"
                    name="country"
                    value="<%= trip.country %>"
                    required>
            </div>

            <div class="form-group">
                <label>Budget (SGD)</label>
                <input
                    type="number"
                    step="0.01"
                    name="budget"
                    value="<%= trip.budget %>"
                    required>
            </div>

        </div>

        <div class="form-row">

            <div class="form-group">
                <label>Start Date</label>
                <input
                    type="date"
                    name="startDate"
                    value="<%= trip.startDate ? new Date(trip.startDate).toISOString().split('T')[0] : '' %>"
                    required>
            </div>

            <div class="form-group">
                <label>End Date</label>
                <input
                    type="date"
                    name="endDate"
                    value="<%= trip.endDate ? new Date(trip.endDate).toISOString().split('T')[0] : '' %>"
                    required>
            </div>

        </div>

        <div class="form-group">

            <label>Current Image</label>

            <% if(trip.image){ %>

                <img
                    src="/images/<%= trip.image %>"
                    class="edit-image">

            <% } else { %>

                <p>No image uploaded.</p>

            <% } %>

        </div>

        <div class="form-group">

            <label>Notes</label>

            <textarea
                name="notes"
                rows="6"><%= trip.notes %></textarea>

        </div>

        <button class="save-btn">
            Update Group Trip
        </button>

    </form>

</div>

</body>
</html>
